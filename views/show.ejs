<% layout("/layouts/boilerplate")%>
<body>
    <div class="row">
        <div class="col-lg-8 offset-2 mt-3">
    <h3> complete detail about your hotel</h3>
</div>
    <div class="card  col-6 offset-2">
  <img src="<%=ourListing.image%>" class="card-img-top show-img " alt="listing_image">
  <div class="card-body mt-2">
    <p class="card-text">
      <b>  <%=ourListing.title%>.</b><br>
      <%=ourListing.description%><br>
      &#8377;<%=ourListing.price?.toLocaleString("en-IN")%><br>
      <%=ourListing.location%><br>
      <%=ourListing.country%><br>


    </p>
  </div>
</div>




    <br>
    <div class="btns gap-2 " style="display: flex; ">
    <a href="/listing/<%=ourListing._id%>/edit" class="btn btn-dark offset-2"  style="width: 6rem;">edit</a>
    <form method="POST" action="/listing/<%=ourListing._id%>?_method=DELETE">
        <button class="offset-2" style="background-color:#fe424b  ; border: none; width: 6rem; height: 2.5rem; border-radius: 5px; color: aliceblue; " >delete </button>
    </form>
    </div>
    <form  action="/listing/<%=ourListing._id%>/review"  method="post"  class="mb-3">
    <div class="col-8 offset-2">
    <hr>
      <h3 > leave a review</h3>
      <div mb-3 mt-3> 
        <label for="rating"  class="form-label"> RATING</label><br>
        <input type="range" class="form-range" name="review[rating]" id="rating"   min="1" max="5"/>
      </div>
      <div mb-3 mt-3> 
        <label  > comment</label><br><br>
        <textarea  class="form-control" name="review[comment]"> </textarea>
      </div><br>
       <button  style="background-color:#fe424b  ; border: none; width: 6rem; height: 2.5rem; border-radius: 5px; color: aliceblue; " >submit </button>
    </div>
    </form>
</body>
</div>
















  