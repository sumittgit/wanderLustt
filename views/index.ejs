<% layout("/layouts/boilerplate")%>
<body>
    <h2> all chats</h2>
    <!-- <form method="GET" action="/listing/new">
        <button>create new</button> </form> -->
        <div class="container">
    <div class="row  " >
<%for(listing of listingData){ %>
<div class=" col-lg-4 col-md-6  col-sm-12 ">
    <a href="/listing/<%=listing._id%>" class="listing-link">
<div class="card"  >
  <img src="<%=listing.image%>" class="card-img-top" alt="listing_image" style = "height: 20rem;"  >
  <div class="card-img-overlay"></div>
  <div class="card-body">
    <p class="card-text">
       <b><%= listing.title%> </b> <br />
       &#8377; <%= listing.price?.toLocaleString("en-IN")%> /night
        .</p>
  </div>
</div>

</a>
</div>
<%}%>
</div></div>
</body>


